{
  "name": "office-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "playwright test",
    "test:e2e": "playwright test",
    "test:ci": "npm run lint && npm run typecheck && npm run build && npm run test:unit:coverage && npm run test:e2e",
    "release:rentals": "bash scripts/release-rental-system.sh"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
